    refuse:     'I WAS THERE'                    (unchanged)
  Statement 02: 'EMILY VALE WAS ABSENT'          -> 'I COULD NOT HAVE DONE ANYTHING'
    correct:    'EMILY VALE WAS THERE'           -> 'I COULD HAVE SAID SOMETHING'
    refuse:     'I DID NOT GIVE THEM YOUR NAME'  -> 'I STARTED TYPING AGAIN'
  Statement 03: 'SECOND CHILD: UNNAMED'          -> 'I WAS JUST A CHILD'
    correct:    'SECOND CHILD: NAMED'            -> 'I KNEW WHAT WAS HAPPENING'
    refuse:     'SECOND CHILD: UNREADY'          -> 'I WAS AFRAID'
  Statement 04: 'THE CHILD COMPLETED THE LESSON' -> 'I KEPT TYPING' (already honest)
